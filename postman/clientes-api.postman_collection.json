{
	"info": {
		"name": "API de Clientes",
		"description": "Collection do desafio técnico — CRUD de clientes.\n\nComo usar:\n1. Ajuste a variável {{baseUrl}} se necessário (padrão: http://localhost:3000);\n2. Execute a collection na ordem (Run collection).\n\nO primeiro cenário gera um CPF válido aleatório e um e-mail único a cada execução (pre-request script), salva o clienteId criado e os demais cenários reutilizam essas variáveis — a collection pode ser executada várias vezes seguidas sem conflito de dados.\n\nTodos os cenários validam automaticamente o código de status, o formato da resposta e as mensagens de erro.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "baseUrl", "value": "https://desafio-drmobile-production.up.railway.app" },
		{ "key": "clienteId", "value": "" },
		{ "key": "cpfValido", "value": "" },
		{ "key": "cpfSecundario", "value": "" },
		{ "key": "emailValido", "value": "" }
	],
	"item": [
		{
			"name": "01 - Cadastro de cliente válido",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"type": "text/javascript",
						"exec": [
							"// gera um CPF matematicamente válido para cada execução da collection",
							"function gerarCpfValido() {",
							"    let n;",
							"    do {",
							"        n = Array.from({ length: 9 }, () => Math.floor(Math.random() * 10));",
							"    } while (n.every((d) => d === n[0]));",
							"    let d1 = 0;",
							"    for (let i = 0; i < 9; i++) d1 += n[i] * (10 - i);",
							"    d1 = 11 - (d1 % 11);",
							"    if (d1 >= 10) d1 = 0;",
							"    n.push(d1);",
							"    let d2 = 0;",
							"    for (let i = 0; i < 10; i++) d2 += n[i] * (11 - i);",
							"    d2 = 11 - (d2 % 11);",
							"    if (d2 >= 10) d2 = 0;",
							"    n.push(d2);",
							"    return n.join('');",
							"}",
							"const agora = Date.now();",
							"pm.collectionVariables.set('cpfValido', gerarCpfValido());",
							"pm.collectionVariables.set('cpfSecundario', gerarCpfValido());",
							"pm.collectionVariables.set('emailValido', `cliente.${agora}@email.com`);"
						]
					}
				},
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('Status deve ser 201', function () {",
							"    pm.response.to.have.status(201);",
							"});",
							"const response = pm.response.json();",
							"pm.test('Resposta contém _id, createdAt e updatedAt', function () {",
							"    pm.expect(response).to.have.property('_id');",
							"    pm.expect(response).to.have.property('createdAt');",
							"    pm.expect(response).to.have.property('updatedAt');",
							"});",
							"pm.test('CPF salvo somente com números', function () {",
							"    pm.expect(response.cpf).to.match(/^\\d{11}$/);",
							"});",
							"pm.test('E-mail salvo em minúsculas', function () {",
							"    pm.expect(response.email).to.eql(response.email.toLowerCase());",
							"});",
							"pm.test('Telefone salvo somente com números', function () {",
							"    pm.expect(response.telefone).to.match(/^\\d{10,13}$/);",
							"});",
							"pm.test('Estado salvo em maiúsculas', function () {",
							"    pm.expect(response.endereco.estado).to.eql('SP');",
							"});",
							"pm.test('Campo ativo tem padrão true', function () {",
							"    pm.expect(response.ativo).to.be.true;",
							"});",
							"pm.collectionVariables.set('clienteId', response._id);"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [{ "key": "Content-Type", "value": "application/json" }],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"nome\": \"João da Silva\",\n  \"cpf\": \"{{cpfValido}}\",\n  \"email\": \"{{emailValido}}\",\n  \"telefone\": \"(11) 99999-9999\",\n  \"dataNascimento\": \"1995-05-10\",\n  \"endereco\": {\n    \"cep\": \"01001-000\",\n    \"logradouro\": \"Praça da Sé\",\n    \"numero\": \"100\",\n    \"complemento\": \"Apartamento 10\",\n    \"bairro\": \"Sé\",\n    \"cidade\": \"São Paulo\",\n    \"estado\": \"sp\"\n  }\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": {
					"raw": "{{baseUrl}}/clientes",
					"host": ["{{baseUrl}}"],
					"path": ["clientes"]
				}
			}
		},
